    "alb_controller_iam_role": {
      "value": "arn:aws:iam::941948905001:role/ecommerce-cluster-alb-controller-role",
      "type": "string"
    },
    "alb_controller_install_command": {
      "value": "# SSH to EC2 and run:\naws eks update-kubeconfig --region us-west-2 --name ecommerce-cluster\n    \n# Create service account with IAM role\nkubectl create serviceaccount aws-load-balancer-controller -n kube-system\nkubectl annotate serviceaccount aws-load-balancer-controller \\\n  -n kube-system \\\n  eks.amazonaws.com/role-arn=arn:aws:iam::941948905001:role/ecommerce-cluster-alb-controller-role\n    \n# Install ALB Controller via Helm\nhelm repo add eks https://aws.github.io/eks-charts\nhelm repo update\nhelm install aws-load-balancer-controller eks/aws-load-balancer-controller \\\n  -n kube-system \\\n  --set clusterName=ecommerce-cluster \\\n  --set serviceAccount.create=false \\\n  --set serviceAccount.name=aws-load-balancer-controller \\\n  --set region=us-west-2 \\\n  --set vpcId=vpc-06bec4472137da9cb\n",
      "type": "string"
    },
    "eks_cluster_endpoint": {
      "value": "https://480F420CF30F6C7C0D15264C8F9DCE89.gr7.us-west-2.eks.amazonaws.com",
      "type": "string"
    },
    "eks_cluster_name": {
      "value": "ecommerce-cluster",
      "type": "string"
    },
    "eks_kubeconfig_command": {
      "value": "aws eks update-kubeconfig --region us-west-2 --name ecommerce-cluster",
      "type": "string"
    },
    "jenkins_public_ip": {
      "value": "44.248.75.132",
      "type": "string"
    },
    "jenkins_url": {
      "value": "http://44.248.75.132:8080",
