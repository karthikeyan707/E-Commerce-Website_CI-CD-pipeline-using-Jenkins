pipeline {
    // Run on single Jenkins instance (Master + Agent combined)
    agent any

    triggers {
        githubPush()
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        SONARQUBE_TOKEN = credentials('sonarqube-token')
        NEXUS_URL = 'localhost:8081'
        NEXUS_CREDENTIALS = credentials('nexus-credentials')
        SERVICES = 'api-gateway product-service order-service user-service frontend'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
                sh 'echo "Build: ${BUILD_NUMBER} | Branch: ${BRANCH_NAME}"'
            }
        }

        stage('Build') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            echo "Building ${service}..."
                            sh 'npm ci'
                        }
                    }
                }
            }
        }

        stage('Unit Tests') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            echo "Testing ${service}..."
                            sh 'npm test || true'
                        }
                    }
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            withSonarQubeEnv('SonarQube') {
                                sh """
                                    npx sonar-scanner \
                                    -Dsonar.projectKey=ecommerce-${service} \
                                    -Dsonar.projectName="E-Commerce ${service}" \
                                    -Dsonar.sources=src
                                """
                            }
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    echo "Building images with tag: ${IMAGE_TAG}"

                    sh """
                       cd docker

                       export IMAGE_TAG=${IMAGE_TAG}
                       export DOCKERHUB_USERNAME=${DOCKERHUB_CREDENTIALS_USR}

                       docker compose -f docker-compose.build.yml build

                       for service in ${SERVICES}; do
                           docker tag \$DOCKERHUB_USERNAME/\$service:\$IMAGE_TAG \$DOCKERHUB_USERNAME/\$service:latest
                       done
                    """
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        sh "trivy image --severity HIGH,CRITICAL --exit-code 0 ${DOCKERHUB_CREDENTIALS_USR}/${service}:${IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                        SERVICES.split(' ').each { service ->
                            sh "docker push ${DOCKERHUB_CREDENTIALS_USR}/${service}:${IMAGE_TAG}"
                            sh "docker push ${DOCKERHUB_CREDENTIALS_USR}/${service}:latest"
                        }
                    }
                }
            }
        }

        stage('Upload to Nexus') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            sh """
                                tar -czf ${service}-${IMAGE_TAG}.tar.gz src package.json package-lock.json
                                curl -u ${NEXUS_CREDENTIALS_USR}:${NEXUS_CREDENTIALS_PSW} --upload-file ${service}-${IMAGE_TAG}.tar.gz \
                                    http://${NEXUS_URL}/repository/ecommerce-artifacts/${service}/${IMAGE_TAG}/
                            """
                        }
                    }
                }
            }
        }

        stage('Approve Deployment') {
            steps {
                script {
                    def userInput = input(
                        id: 'deployApproval',
                        message: 'Deploy to production?',
                        parameters: [
                            choice(name: 'DEPLOY_ENVIRONMENT', choices: ['production', 'staging'], description: 'Environment'),
                            text(name: 'DEPLOY_NOTES', defaultValue: "Build ${BUILD_NUMBER}", description: 'Notes')
                        ]
                    )
                    env.DEPLOY_ENV = userInput.DEPLOY_ENVIRONMENT
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build(
                    job: 'ecommerce-cd',
                    parameters: [
                        string(name: 'IMAGE_TAG', value: "${IMAGE_TAG}"),
                        string(name: 'DEPLOY_ENVIRONMENT', value: "${DEPLOY_ENV}")
                    ],
                    wait: false
                )
            }
        }
    }

    post {
        always {
            sh 'docker logout 2>/dev/null || true'
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
        success {
            echo "============================================"
            echo "  CI PIPELINE SUCCESS"
            echo "  Build #${BUILD_NUMBER}"
            echo "  Image Tag: ${IMAGE_TAG}"
            echo "  Images pushed to DockerHub"
            echo "============================================"
        }
        failure {
            echo "============================================"
            echo "  CI PIPELINE FAILED"
            echo "  Build #${BUILD_NUMBER}"
            echo "  Console: ${BUILD_URL}console"
            echo "============================================"
        }
    }
}
