pipeline {
    // Run on single Jenkins instance (Master + Agent combined)
    agent any

    triggers {
        githubPush()
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        SONARQUBE_TOKEN = credentials('sonarqube-token')
        NEXUS_URL = 'localhost:8081'
        NEXUS_CREDENTIALS = credentials('nexus-credentials')
        DOCKERHUB_USERNAME = 'your-dockerhub-username'
        SERVICES = 'api-gateway product-service order-service user-service frontend'
        BUILD_TIMESTAMP = sh(script: 'date +%Y%m%d%H%M%S', returnStdout: true).trim()
        GIT_COMMIT_SHORT = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
        AWS_DEFAULT_REGION = 'us-west-2'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timeout(time: 45, unit: 'MINUTES')
        timestamps()
    }

    stages {
        stage('Checkout') {
            steps {
                cleanWs()
                checkout scm
                sh 'echo "Build: ${BUILD_NUMBER} | Commit: ${GIT_COMMIT_SHORT} | Branch: ${BRANCH_NAME}"'
            }
        }

        stage('Build') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            echo "Building ${service}..."
                            sh 'npm ci'
                        }
                    }
                }
            }
        }

        stage('Unit Tests') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            echo "Testing ${service}..."
                            sh 'npm test || true'
                        }
                    }
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            withSonarQubeEnv('SonarQube') {
                                sh """
                                    npx sonar-scanner \
                                    -Dsonar.projectKey=ecommerce-${service} \
                                    -Dsonar.projectName="E-Commerce ${service}" \
                                    -Dsonar.sources=src \
                                    -Dsonar.javascript.lcov.reportPaths=coverage/lcov.info
                                """
                            }
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    env.IMAGE_TAG = "${env.GIT_COMMIT_SHORT}-${env.BUILD_NUMBER}"
                    echo "Building images with tag: ${env.IMAGE_TAG}"

                    sh """
                        cd docker
                        IMAGE_TAG=${IMAGE_TAG} DOCKERHUB_USERNAME=${DOCKERHUB_USERNAME} docker-compose -f docker-compose.build.yml build --parallel
                        ${SERVICES.split(' ').collect { service -> "docker tag ${DOCKERHUB_USERNAME}/${service}:${IMAGE_TAG} ${DOCKERHUB_USERNAME}/${service}:latest" }.join('\n                        ')}
                    """
                }
            }
        }

        stage('Security Scan') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        sh "trivy image --severity HIGH,CRITICAL --exit-code 0 ${DOCKERHUB_USERNAME}/${service}:${IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Push to DockerHub') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                        SERVICES.split(' ').each { service ->
                            sh "docker push ${DOCKERHUB_USERNAME}/${service}:${IMAGE_TAG}"
                            sh "docker push ${DOCKERHUB_USERNAME}/${service}:latest"
                        }
                    }
                }
            }
        }

        stage('Upload to Nexus') {
            steps {
                script {
                    SERVICES.split(' ').each { service ->
                        dir(service) {
                            sh """
                                tar -czf ${service}-${IMAGE_TAG}.tar.gz src package.json package-lock.json
                                curl -u ${NEXUS_CREDENTIALS} --upload-file ${service}-${IMAGE_TAG}.tar.gz \
                                    http://${NEXUS_URL}/repository/ecommerce-artifacts/${service}/${IMAGE_TAG}/
                            """
                        }
                    }
                }
            }
        }

        stage('Approve Deployment') {
            steps {
                script {
                    def userInput = input(
                        id: 'deployApproval',
                        message: 'Deploy to production?',
                        parameters: [
                            choice(name: 'DEPLOY_ENVIRONMENT', choices: ['production', 'staging'], description: 'Environment'),
                            text(name: 'DEPLOY_NOTES', defaultValue: "Build ${BUILD_NUMBER} - ${IMAGE_TAG}", description: 'Notes')
                        ]
                    )
                    env.DEPLOY_ENV = userInput.DEPLOY_ENVIRONMENT
                }
            }
        }

        stage('Trigger CD') {
            steps {
                build(
                    job: 'ecommerce-cd',
                    parameters: [
                        string(name: 'IMAGE_TAG', value: "${IMAGE_TAG}"),
                        string(name: 'DEPLOY_ENVIRONMENT', value: "${DEPLOY_ENV}")
                    ],
                    wait: false
                )
            }
        }
    }

    post {
        always {
            sh 'docker logout 2>/dev/null || true'
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
        success {
            echo "============================================"
            echo "  CI PIPELINE SUCCESS"
            echo "  Build #${BUILD_NUMBER}"
            echo "  Image Tag: ${IMAGE_TAG}"
            echo "  Status: BUILD, TEST, SCAN COMPLETED"
            echo "  Images pushed to DockerHub"
            echo "  Artifacts uploaded to Nexus"
            echo "============================================"
        }
        failure {
            echo "============================================"
            echo "  CI PIPELINE FAILED"
            echo "  Build #${BUILD_NUMBER}"
            echo "  Image Tag: ${IMAGE_TAG}"
            echo "  Status: BUILD FAILED"
            echo "  Console: ${BUILD_URL}console"
            echo "============================================"
        }
    }
}
