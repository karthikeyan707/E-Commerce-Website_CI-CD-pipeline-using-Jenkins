pipeline {

    agent any

    environment {
        AWS_CREDENTIALS = credentials('aws-credentials')
        GITHUB_CREDENTIALS = credentials('github-token')
        DOCKERHUB_CREDENTIALS = credentials('dockerhub-credentials')
        EKS_CLUSTER_NAME = 'ecommerce-cluster'
        AWS_REGION = 'us-west-2'
        K8S_REPO = 'https://github.com/karthikeyan707/E-Commerce-Website_CI-CD-pipeline-using-Jenkins.git'
        SERVICES = 'api-gateway product-service order-service user-service frontend'
    }

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag to deploy')
        string(name: 'DEPLOY_ENVIRONMENT', defaultValue: 'staging', description: 'Deployment environment')
        string(name: 'DEPLOY_NOTES', defaultValue: '', description: 'Deployment notes')
        booleanParam(name: 'DRY_RUN', defaultValue: false, description: 'Perform dry run without actual deployment')
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {
        stage('Checkout K8s Manifests') {
            steps {
                cleanWs()
                git branch: 'main', credentialsId: 'github-token', url: "${K8S_REPO}"
            }
        }

        stage('Configure AWS & EKS') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']]) {
                    sh """
                        aws configure set aws_access_key_id ${AWS_ACCESS_KEY_ID}
                        aws configure set aws_secret_access_key ${AWS_SECRET_ACCESS_KEY}
                        aws configure set region ${AWS_REGION}
                        aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER_NAME}
                        kubectl cluster-info
                        kubectl get nodes
                    """
                }
            }
        }

        stage('Update Image Tags') {
            steps {
                script {
                    def tag = params.IMAGE_TAG == 'latest' ? sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim() : params.IMAGE_TAG
                    SERVICES.split(' ').each { service ->
                        sh "sed -i 's|image: .*/${service}:.*|image: ${DOCKERHUB_CREDENTIALS_USR}/${service}:${tag}|g' k8s/base/deployment-${service}.yaml"
                    }
                    sh 'git diff k8s/base/'
                }
            }
        }

        stage('Deploy to EKS') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                script {
                    def namespace = params.DEPLOY_ENVIRONMENT
                    sh """
                        kubectl create namespace ${namespace} --dry-run=client -o yaml | kubectl apply -f -

                        # Apply ConfigMaps and Secrets
                        for f in k8s/base/configmap-*.yaml k8s/base/secret-*.yaml; do
                            kubectl apply -f \$f -n ${namespace} || true
                        done

                        # Apply deployments
                        for service in ${SERVICES}; do
                            kubectl apply -f k8s/base/deployment-\${service}.yaml -n ${namespace}
                        done

                        # Apply HPA
                        kubectl apply -f k8s/base/hpa.yaml -n ${namespace} || true

                        # Apply Ingress
                        kubectl apply -f k8s/base/ingress-nginx.yaml -n ${namespace}
                    """
                }
            }
        }

        stage('Verify Rollout') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                script {
                    def namespace = params.DEPLOY_ENVIRONMENT
                    SERVICES.split(' ').each { service ->
                        sh "kubectl rollout status deployment/${service} -n ${namespace} --timeout=300s"
                    }
                    sh """
                        echo "=== Deployment Status ==="
                        kubectl get pods,svc,deployments,ingress -n ${namespace}
                        
                        echo ""
                        echo "=== NGINX Ingress URL (CLB) ==="
                        kubectl get svc ingress-nginx-controller -n ingress-nginx -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' || echo "CLB still provisioning..."
                    """
                }
            }
        }
    }

    post {
        always {
            cleanWs(deleteDirs: true, notFailBuild: true)
        }
        success {
            echo "============================================"
            echo "  CD PIPELINE SUCCESS"
            echo "  Environment: ${params.DEPLOY_ENVIRONMENT}"
            echo "  Image Tag: ${params.IMAGE_TAG}"
            echo "  Build #${BUILD_NUMBER}"
            echo "  Status: DEPLOYMENT COMPLETED SUCCESSFULLY"
            echo "============================================"
        }
        failure {
            script {
                if (!params.DRY_RUN) {
                    SERVICES.split(' ').each { service ->
                        sh "kubectl rollout undo deployment/${service} -n ${params.DEPLOY_ENVIRONMENT} || true"
                    }
                }
            }
            echo "============================================"
            echo "  CD PIPELINE FAILED"
            echo "  Environment: ${params.DEPLOY_ENVIRONMENT}"
            echo "  Image Tag: ${params.IMAGE_TAG}"
            echo "  Build #${BUILD_NUMBER}"
            echo "  Status: DEPLOYMENT FAILED - ROLLBACK EXECUTED"
            echo "  Console: ${BUILD_URL}console"
            echo "============================================"
        }
    }
}
