pipeline {
    agent any
    
    environment {
        AWS_CREDENTIALS = credentials('aws-credentials')
        GITHUB_CREDENTIALS = credentials('github-token')
        DOCKERHUB_USERNAME = 'your-dockerhub-username'
        EKS_CLUSTER_NAME = 'ecommerce-cluster'
        AWS_REGION = 'us-east-1'
        K8S_REPO = 'https://github.com/yourusername/ecommerce-k8s-manifests.git'
        SERVICES = 'api-gateway product-service order-service'
    }
    
    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag to deploy')
        choice(name: 'ENVIRONMENT', choices: ['staging', 'production'], description: 'Deployment environment')
        booleanParam(name: 'DRY_RUN', defaultValue: false, description: 'Perform dry run without actual deployment')
    }
    
    stages {
        stage('Checkout K8s Manifests') {
            steps {
                cleanWs()
                git branch: 'main', credentialsId: 'github-token', url: "${K8S_REPO}"
            }
        }
        
        stage('Configure AWS') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'aws-credentials']]) {
                    sh """
                        aws configure set aws_access_key_id ${AWS_ACCESS_KEY_ID}
                        aws configure set aws_secret_access_key ${AWS_SECRET_ACCESS_KEY}
                        aws configure set region ${AWS_REGION}
                        aws eks update-kubeconfig --region ${AWS_REGION} --name ${EKS_CLUSTER_NAME}
                    """
                }
            }
        }
        
        stage('Update Image Tags') {
            steps {
                script {
                    def tag = params.IMAGE_TAG == 'latest' ? sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim() : params.IMAGE_TAG
                    
                    SERVICES.split(' ').each { service ->
                        echo "Updating ${service} image tag to ${tag}..."
                        sh """
                            sed -i 's|image: ${DOCKERHUB_USERNAME}/${service}:.*|image: ${DOCKERHUB_USERNAME}/${service}:${tag}|g' k8s/base/deployment-${service}.yaml
                        """
                    }
                    
                    // Show changes
                    sh 'git diff k8s/base/'
                }
            }
        }
        
        stage('Deploy to EKS') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                script {
                    def namespace = params.ENVIRONMENT == 'production' ? 'production' : 'staging'
                    
                    sh """
                        # Create namespace if not exists
                        kubectl create namespace ${namespace} --dry-run=client -o yaml | kubectl apply -f -
                        
                        # Apply ConfigMaps and Secrets
                        kubectl apply -f k8s/base/configmap-*.yaml -n ${namespace}
                        kubectl apply -f k8s/base/secret-db.yaml -n ${namespace}
                        
                        # Apply deployments
                        kubectl apply -f k8s/base/deployment-api-gateway.yaml -n ${namespace}
                        kubectl apply -f k8s/base/deployment-product-service.yaml -n ${namespace}
                        kubectl apply -f k8s/base/deployment-order-service.yaml -n ${namespace}
                        
                        # Apply HPA
                        kubectl apply -f k8s/base/hpa.yaml -n ${namespace}
                    """
                    
                    // Apply Ingress only for production
                    if (params.ENVIRONMENT == 'production') {
                        sh 'kubectl apply -f k8s/base/ingress.yaml -n ${namespace}'
                    }
                }
            }
        }
        
        stage('Verify Rollout') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                script {
                    def namespace = params.ENVIRONMENT == 'production' ? 'production' : 'staging'
                    def timeout = 300 // 5 minutes
                    
                    SERVICES.split(' ').each { service ->
                        echo "Verifying rollout for ${service}..."
                        sh """
                            kubectl rollout status deployment/${service} -n ${namespace} --timeout=${timeout}s
                        """
                    }
                    
                    // Check pod status
                    sh """
                        echo "=== Pod Status ==="
                        kubectl get pods -n ${namespace}
                        
                        echo "=== Service Status ==="
                        kubectl get svc -n ${namespace}
                    """
                }
            }
        }
        
        stage('Smoke Tests') {
            when {
                expression { !params.DRY_RUN }
            }
            steps {
                script {
                    def namespace = params.ENVIRONMENT == 'production' ? 'production' : 'staging'
                    def gatewayUrl = params.ENVIRONMENT == 'production' ? 'https://api.yourdomain.com' : 'http://api-gateway-staging.yourdomain.com'
                    
                    // Wait for services to be ready
                    sleep(time: 30, unit: 'SECONDS')
                    
                    // Health check
                    sh """
                        echo "Testing health endpoints..."
                        curl -f ${gatewayUrl}/health || exit 1
                    """
                    
                    echo "Smoke tests passed!"
                }
            }
        }
        
        stage('Commit Manifests') {
            when {
                expression { !params.DRY_RUN && params.ENVIRONMENT == 'production' }
            }
            steps {
                script {
                    sh """
                        git config user.email "jenkins@yourdomain.com"
                        git config user.name "Jenkins"
                        git add k8s/base/
                        git commit -m "Update image tags to ${params.IMAGE_TAG} - Build #${BUILD_NUMBER}" || echo "No changes to commit"
                        git push origin main
                    """
                }
            }
        }
    }
    
    post {
        always {
            cleanWs()
        }
        success {
            echo "Deployment to ${params.ENVIRONMENT} completed successfully!"
            slackSend color: 'good', message: "CD SUCCESS: E-Commerce deployed to ${params.ENVIRONMENT} - Build #${BUILD_NUMBER}"
        }
        failure {
            echo 'Deployment failed! Initiating rollback...'
            script {
                if (!params.DRY_RUN) {
                    def namespace = params.ENVIRONMENT == 'production' ? 'production' : 'staging'
                    
                    SERVICES.split(' ').each { service ->
                        sh """
                            echo "Rolling back ${service}..."
                            kubectl rollout undo deployment/${service} -n ${namespace}
                        """
                    }
                }
            }
            slackSend color: 'danger', message: "CD FAILED: E-Commerce deployment to ${params.ENVIRONMENT} failed - Build #${BUILD_NUMBER}. Rollback initiated."
        }
    }
}
